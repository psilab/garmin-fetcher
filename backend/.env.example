# Only needed for the one-time `python login.py` bootstrap.
# The API service itself runs on saved tokens and needs neither of these.
GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=your-password

# Static bearer token required on every request to the /mcp mount (SEC-02).
# Generate with: openssl rand -hex 32
# Put the real value here for dev, and in the prod host's environment/secrets
# store for docker-compose.yml. Never commit the actual value -- only
# .mcp.json's ${MCP_TOKEN} reference is committed.
# MCP_TOKEN=
